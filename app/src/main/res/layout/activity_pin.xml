<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a2e18">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- LOGO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐔"
                android:textSize="56sp"/>

            <!-- TITOLO -->
            <TextView
                android:id="@+id/tv_pin_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accedi al Pollaio"
                android:textColor="#ffffff"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/tv_pin_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inserisci email e PIN"
                android:textColor="#80ffffff"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- EMAIL — rettangolo bianco su sfondo verde -->
            <EditText
                android:id="@+id/et_username"
                android:layout_width="280dp"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                android:hint="Email"
                android:textColor="#1a2e18"
                android:textColorHint="#888888"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/input_bg"
                android:inputType="textEmailAddress"
                android:imeOptions="actionNext"
                android:singleLine="true"/>

            <!-- DOTS -->
            <LinearLayout
                android:id="@+id/dots_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <ImageView android:id="@+id/dot1" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="10dp" android:src="@drawable/dot_empty"/>
                <ImageView android:id="@+id/dot2" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="10dp" android:src="@drawable/dot_empty"/>
                <ImageView android:id="@+id/dot3" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="10dp" android:src="@drawable/dot_empty"/>
                <ImageView android:id="@+id/dot4" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="10dp" android:src="@drawable/dot_empty"/>
            </LinearLayout>

            <!-- ERRORE -->
            <TextView
                android:id="@+id/tv_pin_error"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#ff6b6b"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- TASTIERINO — tasti più compatti -->
            <GridLayout
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="4"
                android:layout_marginTop="4dp">

                <com.google.android.material.button.MaterialButton android:id="@+id/btn1" style="@style/PinButton" android:text="1"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn2" style="@style/PinButton" android:text="2"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn3" style="@style/PinButton" android:text="3"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn4" style="@style/PinButton" android:text="4"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn5" style="@style/PinButton" android:text="5"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn6" style="@style/PinButton" android:text="6"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn7" style="@style/PinButton" android:text="7"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn8" style="@style/PinButton" android:text="8"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn9" style="@style/PinButton" android:text="9"/>
                <View android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="6dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn0" style="@style/PinButton" android:text="0"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_del" style="@style/PinButton" android:text="⌫" android:textSize="18sp"/>
            </GridLayout>

        </LinearLayout>
    </ScrollView>

    <!-- LOADING OVERLAY -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="#ffffff"/>
    </FrameLayout>

</FrameLayout>
